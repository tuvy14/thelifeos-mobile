# Copy to .env.local and fill in. Both values are public-safe (the anon key is a
# Supabase *publishable* key) — they ship in the client either way. Cloud sync is
# disabled and the app stays fully local until these are set.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Stripe checkout. Create two hosted **Payment Links** in your Stripe dashboard
# (Products → Payment Links). Paste their public URLs here — these are NOT secret
# keys (never put sk_live_… / sk_test_… / whsec_… in the app). Until set, the
# paywall/Upgrade screen shows the plans but checkout is disabled.
#
#   LIFETIME → a ONE-TIME $300 payment link.
#   MONTHLY  → a $15/mo *subscription* link with a **3-day free trial** set on the
#              price (Stripe → the recurring price → "Add free trial: 3 days").
#              Stripe collects the card and charges nothing for 3 days.
#
# Apple Pay: nothing to configure in the app. On iOS the link opens in a Safari
# sheet, and Stripe shows the Apple Pay button automatically once you enable it in
# the dashboard: Settings → Payment methods → turn on **Apple Pay**, and register
# the buy.stripe.com domain (Stripe does this for hosted Payment Links by default).
#
# Note: the app grants access on return from checkout (honor-system) — it can't
# verify payment on-device without a secret key. For hard enforcement, add a
# Stripe webhook → your backend → Supabase and check entitlement server-side.
EXPO_PUBLIC_STRIPE_LIFETIME_URL=https://buy.stripe.com/your_lifetime_link
EXPO_PUBLIC_STRIPE_MONTHLY_URL=https://buy.stripe.com/your_monthly_trial_link
